#!/usr/bin/env ruby

# 1. Identify paths
REAL_PATH = File.realpath(__FILE__)
# In a gem, bin/friday is inside 'bin', so project root is one level up
PROJECT_DIR = File.expand_path("..", File.dirname(REAL_PATH))

# 2. Add lib to load path
$LOAD_PATH.unshift File.join(PROJECT_DIR, "lib") unless $LOAD_PATH.include?(File.join(PROJECT_DIR, "lib"))

# 3. Use Bundler ONLY if running from the source folder in development
# (Determined by presence of a Gemfile and not being in a gem install path)
gemfile = File.join(PROJECT_DIR, "Gemfile")
if File.exist?(gemfile) && !REAL_PATH.include?("/gems/") && !ENV["FRIDAY_NO_BUNDLER"]
  ENV["BUNDLE_GEMFILE"] = gemfile
  require "bundler/setup"
end

require "friday"

# 4. Initialize and Start
# The CLI handles checking and prompting for project setup
Friday::Cli.start(ARGV)
